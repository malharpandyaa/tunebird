{
  "name": "tunebird",
  "version": "1.0.0",
  "description": "Browse YouTube and send music straight to your iPhone",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.tunebird.app",
    "productName": "TuneBird",
    "copyright": "Copyright © 2025",
    "mac": {
      "category": "public.app-category.music",
      "target": [{ "target": "dmg", "arch": ["universal"] }],
      "icon": "assets/icon.icns",
      "minimumSystemVersion": "12.0"
    },
    "dmg": {
      "title": "TuneBird",
      "background": "assets/dmg-bg.png",
      "window": { "width": 540, "height": 380 }
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!**/*.map"
    ]
  }
}
