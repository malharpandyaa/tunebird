{
  "name": "tunebird",
  "version": "1.0.0",
  "description": "Browse YouTube and send music straight to your iPhone",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "posthog-node": "^4.0.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.tunebird.app",
    "productName": "TuneBird",
    "copyright": "Copyright © 2025",
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "minimumSystemVersion": "12.0",
      "extraResources": [
        {
          "from": "bin/",
          "to": "bin/",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "malharpandyaa",
      "repo": "tunebird"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!**/*.map"
    ]
  }
}